# Odysseus — local config. Copy to .env and edit. (.env is gitignored repo-wide.)
#
#   cp .env.example .env
#
# This stack points Odysseus at THIS box's own model serving (the vLLM/SGLang/
# llama.cpp containers under ../models/), NOT at Odysseus' in-app Cookbook
# downloader. Only the loopback interface is bound — keep it that way.

# ============================================================
# Local model wiring
# ============================================================
# Host that runs your inference servers, as seen from inside the container.
LLM_HOST=host.docker.internal
LLM_HOSTS=host.docker.internal

# Odysseus auto-scans ports 8000-8020 + 1234 + 11434 on each host, plus any port
# embedded in a provider URL below. Our convention on this box serves the active
# model on 11436 (same port LibreChat uses). Putting :11436 here adds it to the
# scan so the served model (e.g. qwen3.6-27b) shows up in Odysseus. If you swap
# in a model on a different port, change 11436 here to match.
OLLAMA_BASE_URL=http://host.docker.internal:11436/v1

# vLLM ignores the key but the OpenAI client wants one present. Any value works.
OPENAI_API_KEY=local-vllm

# Deep Research generation endpoint — reuse the local model (full chat path).
RESEARCH_LLM_ENDPOINT=http://host.docker.internal:11436/v1/chat/completions

# Embeddings for RAG/memory. Left blank => local fastembed ONNX fallback
# (~50 MB, downloaded on first use). To use a served embedding model instead,
# stand up ../models/qwen3-embedding and set, e.g.:
#   EMBEDDING_URL=http://host.docker.internal:11438/v1/embeddings
#   EMBEDDING_MODEL=qwen3-embedding
# EMBEDDING_URL=
# EMBEDDING_MODEL=

# ============================================================
# Auth & security  (do NOT disable for anything network-reachable)
# ============================================================
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
APP_BIND=127.0.0.1
APP_PORT=7000
# Pre-seed the first admin password (change it, don't commit a real one).
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=change_me_before_first_boot

# ============================================================
# Host user (bind-mount ownership for ./data and ./logs)
# ============================================================
PUID=1000
PGID=1000

# ============================================================
# Optional
# ============================================================
# HF_TOKEN=                # only if Cookbook ever pulls gated models in-container
# SEARXNG_SECRET=          # auto-generated on first boot if blank
# CHROMADB_BIND=127.0.0.1
# NTFY_BIND=127.0.0.1
